---
interface SeriesArticle {
  slug: string;
  title: string;
  seriesOrder: number;
}

interface Props {
  seriesTitle: string;
  seriesSlug: string;
  currentOrder: number;
  articles: SeriesArticle[];
}

const { seriesTitle, seriesSlug, currentOrder, articles } = Astro.props;

const sorted = [...articles].sort((a, b) => a.seriesOrder - b.seriesOrder);
const currentIndex = sorted.findIndex((a) => a.seriesOrder === currentOrder);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
---

<nav class="mt-16 pt-10 border-t border-gray-200 dark:border-neutral-800">
  <!-- Horizontal step indicator -->
  <div class="flex items-center justify-center gap-1.5 mb-2">
    {sorted.map((article) => {
      const isCurrent = article.seriesOrder === currentOrder;
      const isPast = article.seriesOrder < currentOrder;
      return (
        <a
          href={isCurrent ? undefined : `/writing/${article.slug}`}
          class:list={[
            "block rounded-full transition-all",
            isCurrent
              ? "w-6 h-1.5 bg-blue-500 cursor-default"
              : isPast
                ? "w-1.5 h-1.5 bg-blue-300 dark:bg-blue-700 hover:bg-blue-500 hover:scale-150"
                : "w-1.5 h-1.5 bg-gray-200 dark:bg-neutral-800 hover:bg-blue-400 hover:scale-150",
          ]}
          title={`Week ${article.seriesOrder}: ${article.title}`}
        />
      );
    })}
  </div>

  <a
    href={`/series/${seriesSlug}`}
    class="block text-center text-[11px] text-gray-400 dark:text-neutral-600 hover:text-blue-500 dark:hover:text-blue-400 transition-colors mb-8"
  >
    {seriesTitle} &middot; Week {currentOrder} of {sorted.length}
  </a>

  <!-- Prev / Next -->
  <div class="flex items-stretch gap-3">
    {prev ? (
      <a
        href={`/writing/${prev.slug}`}
        class="group flex-1 flex items-center gap-3 py-3 px-4 rounded-xl bg-gray-50 dark:bg-neutral-900/50 hover:bg-gray-100 dark:hover:bg-neutral-900 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round"
          class="text-gray-300 dark:text-neutral-700 group-hover:text-blue-500 transition-colors flex-shrink-0">
          <path d="m15 18-6-6 6-6" />
        </svg>
        <div class="min-w-0">
          <div class="text-[10px] uppercase tracking-wider text-gray-400 dark:text-neutral-600 mb-0.5">Week {prev.seriesOrder}</div>
          <div class="text-sm text-gray-700 dark:text-neutral-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">{prev.title}</div>
        </div>
      </a>
    ) : (
      <div class="flex-1" />
    )}
    {next ? (
      <a
        href={`/writing/${next.slug}`}
        class="group flex-1 flex items-center justify-end gap-3 py-3 px-4 rounded-xl bg-gray-50 dark:bg-neutral-900/50 hover:bg-gray-100 dark:hover:bg-neutral-900 transition-colors text-right"
      >
        <div class="min-w-0">
          <div class="text-[10px] uppercase tracking-wider text-gray-400 dark:text-neutral-600 mb-0.5">Week {next.seriesOrder}</div>
          <div class="text-sm text-gray-700 dark:text-neutral-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">{next.title}</div>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round"
          class="text-gray-300 dark:text-neutral-700 group-hover:text-blue-500 transition-colors flex-shrink-0">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </a>
    ) : (
      <div class="flex-1" />
    )}
  </div>
</nav>
