---
import Layout from "./Layout.astro";

import { SEO } from "astro-seo";

// src/layouts/BlogPostLayout.astro

interface SeriesArticle {
	slug: string;
	title: string;
	seriesOrder: number;
}

interface PostData {
	title: string;
	subtitle?: string;
	description: string;
	date: string;
	formattedDate: string;
	readingTime: number;
	tags: string[];
	slug: string;
	image: string;
	siteUrl: string;
	coverImage?: ImageMetadata;
	recommendedNext?: string;
	series?: string;
	seriesTitle?: string;
	seriesOrder?: number;
}

interface RecommendedArticle {
	slug: string;
	title: string;
	description: string;
	readingTime: number;
}

const { postData, seriesArticles = [], recommendedArticle } = Astro.props;
import ShareButton from "../components/ShareButton.astro";
import XShare from "../components/XShare.astro";
import SeriesNavigation from "../components/SeriesNavigation.astro";
// SeriesSidebar content is now inlined in the unified right sidebar

// Get the cover image URL for social sharing
const siteUrl = "https://robertjkirk.com";
const defaultImage = `${siteUrl}/images/default-image.png`;
const ogImage = postData.coverImage
	? `${siteUrl}${postData.coverImage.src}`
	: defaultImage;
---

<Layout>
  <Fragment slot="head">
    <SEO
      title={postData.title}
      description={postData.description}
      openGraph={{
        basic: {
          title: postData.title,
          type: "Article",
          image: ogImage,
        },
      }}
      extend={{
        // extending the default link tags
        link: [{ rel: "icon", href: "/favicon.ico" }],
        // extending the default meta tags
        meta: [
          {
            name: "twitter:image",
            content: ogImage,
          },
          { name: "twitter:title", content: postData.title },
          { name: "twitter:description", content: postData.description },
          { name: "twitter:card", content: "summary_large_image" },
        ],
      }}
    />
  </Fragment>
  <div class="min-h-screen p-2 px-0.5 sm:p-4 sm:px-1 xl:p-8 transition-all">
    <div class="max-w-[50rem] mx-auto relative">
      <!-- Right sidebar: actions + TOC + series -->
      <div class="hidden xl:block absolute -right-[11rem] top-0 w-40 h-full pointer-events-none">
        <div class="sticky top-8 pointer-events-auto">
          <!-- Action buttons — compact horizontal row -->
          <div class="flex items-center gap-1.5 mb-8">
            <a
              href="/"
              class="w-8 h-8 rounded-full bg-gray-100 dark:bg-neutral-800 flex items-center justify-center text-gray-400 dark:text-neutral-500 hover:bg-gray-200 hover:text-gray-600 dark:hover:bg-neutral-700 dark:hover:text-neutral-300 transition-colors"
              aria-label="Close and go back"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </a>
            <XShare />
            <ShareButton
              title={postData.title}
              text={postData.description}
              url={postData.slug}
            />
          </div>

          <!-- Table of Contents -->
          <nav id="table-of-contents" class="border-l-2 border-gray-100 dark:border-neutral-800 pl-3">
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-300 dark:text-neutral-700">
              Contents
            </span>
            <div id="toc-links" class="mt-2.5 space-y-0.5"></div>
          </nav>

          <!-- Series navigation -->
          {postData.series && postData.seriesOrder && seriesArticles.length > 0 && (
            <div class="mt-8 border-l-2 border-gray-100 dark:border-neutral-800 pl-3">
              <a href={`/series/${postData.series}`} class="group flex items-center gap-1.5 mb-3">
                <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-300 dark:text-neutral-700 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors">
                  {postData.seriesTitle || postData.series}
                </span>
              </a>
              <div class="space-y-px">
                {[...seriesArticles].sort((a, b) => a.seriesOrder - b.seriesOrder).map((article) => {
                  const isCurrent = article.seriesOrder === postData.seriesOrder;
                  return (
                    <a
                      href={isCurrent ? undefined : `/writing/${article.slug}`}
                      class:list={[
                        "group flex items-start gap-2 py-1.5 transition-all",
                        isCurrent ? "cursor-default" : "hover:translate-x-0.5",
                      ]}
                    >
                      <span
                        class:list={[
                          "w-4 h-4 rounded flex items-center justify-center flex-shrink-0 text-[9px] font-bold transition-colors mt-px",
                          isCurrent
                            ? "bg-blue-500 text-white"
                            : "bg-gray-100 dark:bg-neutral-900 text-gray-400 dark:text-neutral-600 group-hover:bg-blue-50 dark:group-hover:bg-blue-950/30 group-hover:text-blue-500",
                        ]}
                      >
                        {article.seriesOrder}
                      </span>
                      <span
                        class:list={[
                          "text-[11px] leading-snug transition-colors",
                          isCurrent
                            ? "text-gray-900 dark:text-neutral-100 font-medium"
                            : "text-gray-400 dark:text-neutral-600 group-hover:text-gray-700 dark:group-hover:text-neutral-300",
                        ]}
                      >
                        {article.title}
                      </span>
                    </a>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Article -->
      <article
        class="bg-white dark:bg-zinc-950 rounded-3xl p-3 sm:p-6 md:p-12 transition-all shadow-sm border border-gray-100 dark:border-zinc-900"
      >
        <div
          class="xl:hidden sticky top-4 float-right cursor-pointer z-50 gap-3 flex flex-col items-center bg-white/10 dark:bg-black/5 backdrop-blur-lg px-2 py-2 rounded-3xl"
        >
          <a
            href="/"
            class="w-8 h-8 rounded-full bg-gray-100 dark:bg-neutral-800 flex items-center justify-center text-gray-400 dark:text-neutral-500 hover:bg-gray-200 hover:text-gray-600 dark:hover:bg-neutral-700 dark:hover:text-neutral-300 transition-colors"
            aria-label="Close and go back"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </a>
          <XShare />
          <ShareButton
            title={postData.title}
            text={postData.description}
            url={postData.slug}
          />
        </div>
        <header class="mb-8 relative mr-12 xl:mr-0">
          <!-- <a
      href=`https://twitter.com/share?url=${encodeURIComponent(Astro.url)}&text=Check%20out%20this%20article!`
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share this article on Twitter"
      class="sticky top-4 float-right bg-gray-100  text-sm px-3 py-3 rounded-full border border-blue-500 text-blue-500 transition-colors"
      aria-label="Share this article"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-share"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/></svg>
      </a> -->
          <!-- <ShareButton 
  title="𝕏"
  text="Check out this great article!"
  url="https://example.com/article"
/> -->

          {postData.series && postData.seriesOrder && (
            <a
              href={`/series/${postData.series}`}
              class="inline-flex items-center gap-1.5 text-xs text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors mb-3"
            >
              {postData.seriesTitle || postData.series} &middot; Week {postData.seriesOrder}
            </a>
          )}
          <div
            class="flex items-center gap-2 text-sm text-gray-500 dark:text-neutral-500 mb-3"
          >
            <time datetime={postData.date}>{postData.formattedDate}</time>
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-500"
            ></span>
            <span>{postData.readingTime} min read </span>
          </div>
          <h1
            class="text-4xl font-bold text-gray-900 dark:text-neutral-300 mb-4"
            transition:name={`title-${postData.slug}`}
          >
            {postData.title}
          </h1>
          {postData.subtitle && (
            <p class="text-lg text-gray-500 dark:text-neutral-500 mb-4 italic">
              {postData.subtitle}
            </p>
          )}
          <p class="text-xl text-gray-600 dark:text-neutral-400">
            {postData.description}
          </p>
          <div class="flex flex-wrap mt-1">
            {
              postData.tags &&
                postData.tags.map((tag: string, index: number) => {
                  return (
                    <span class=" bg-gray-100 text-gray-500 dark:text-neutral-500 dark:bg-neutral-600/30 text-sm px-2 py-0.5 rounded-lg mt-4 mr-2">
                      {tag}
                    </span>
                  );
                })
            }
          </div>

          <hr
            class="my-8 mb-12 border-t border-gray-300 dark:border-neutral-700"
          />
        </header>

        <!-- Article Content -->
        <div
          class="prose prose-gray max-w-none dark:text-neutral-300 dark:prose-invert prose-a:text-blue-500 prose-hr:border-gray-300 prose-hr:dark:border-neutral-700"
        >
          <slot />
        </div>

        {postData.series && postData.seriesOrder && seriesArticles.length > 0 && (
          <SeriesNavigation
            seriesTitle={postData.seriesTitle || postData.series}
            seriesSlug={postData.series}
            currentOrder={postData.seriesOrder}
            articles={seriesArticles}
          />
        )}
      </article>

      <!-- Post footer -->
      <div class="mt-10 space-y-4">
        {recommendedArticle && (
          <a
            href={`/writing/${recommendedArticle.slug}`}
            class="group block rounded-2xl border border-gray-200 dark:border-neutral-800 p-5 hover:border-blue-500 dark:hover:border-blue-500 transition-all"
          >
            <span class="text-xs font-medium text-gray-400 dark:text-neutral-600 uppercase tracking-wider">
              Read next
            </span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-neutral-200 mt-1.5 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              {recommendedArticle.title}
            </h3>
            <p class="text-sm text-gray-500 dark:text-neutral-500 mt-1 line-clamp-2">
              {recommendedArticle.description}
            </p>
            <span class="text-xs text-gray-400 dark:text-neutral-600 mt-2 inline-block">
              {recommendedArticle.readingTime} min read
            </span>
          </a>
        )}

        <div class="flex justify-center">
          <a
            href="/"
            class="group inline-flex items-center gap-2 text-sm text-gray-400 dark:text-neutral-600 hover:text-gray-600 dark:hover:text-neutral-400 transition-colors py-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:-translate-x-0.5 transition-transform">
              <path d="m15 18-6-6 6-6" />
            </svg>
            Back to home
          </a>
        </div>
      </div>
    </div>
  </div>
  <script>
    function initTOC() {
      const article = document.querySelector('.prose');
      const tocContainer = document.getElementById('toc-links');
      const tocNav = document.getElementById('table-of-contents');
      if (!article || !tocContainer) return;

      // Clear any previous TOC content (for View Transitions)
      tocContainer.innerHTML = '';

      const headings = article.querySelectorAll('h2');
      if (headings.length === 0) {
        if (tocNav) tocNav.style.display = 'none';
        return;
      }
      if (tocNav) tocNav.style.display = '';

      headings.forEach((heading) => {
        if (!heading.id) return;
        const link = document.createElement('a');
        link.href = `#${heading.id}`;
        link.textContent = heading.textContent || '';
        link.className = 'toc-link block text-[11px] leading-snug py-1 -ml-[calc(0.75rem+2px)] pl-[calc(0.75rem-1px)] border-l-[3px] border-transparent text-gray-400 dark:text-neutral-600 hover:text-gray-600 dark:hover:text-neutral-400 transition-all';
        link.dataset.headingId = heading.id;
        tocContainer.appendChild(link);
      });

      // Scroll spy: highlight active heading with left accent
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              tocContainer.querySelectorAll('a').forEach((link) => {
                if (link.dataset.headingId === id) {
                  link.classList.remove('text-gray-400', 'dark:text-neutral-600', 'border-transparent');
                  link.classList.add('text-gray-900', 'dark:text-neutral-200', 'font-medium', 'border-blue-500');
                } else {
                  link.classList.remove('text-gray-900', 'dark:text-neutral-200', 'font-medium', 'border-blue-500');
                  link.classList.add('text-gray-400', 'dark:text-neutral-600', 'border-transparent');
                }
              });
            }
          });
        },
        { rootMargin: '-80px 0px -70% 0px' }
      );

      headings.forEach((heading) => {
        if (heading.id) observer.observe(heading);
      });
    }

    // Run on initial load and after View Transitions navigation
    initTOC();
    document.addEventListener('astro:after-swap', initTOC);
  </script>
</Layout>
