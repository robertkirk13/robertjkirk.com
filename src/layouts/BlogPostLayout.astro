---
import Layout from "./Layout.astro";
import { SEO } from "astro-seo";
import ShareButton from "../components/ShareButton.astro";
import XShare from "../components/XShare.astro";

interface PostData {
  title: string;
  description: string;
  date: string;
  formattedDate: string;
  readingTime: number;
  tags: string[];
  slug: string;
  image: string;
  siteUrl: string;
  coverImage?: ImageMetadata;
}

const { postData } = Astro.props;

const siteUrl = "https://robertjkirk.com";
const defaultImage = `${siteUrl}/images/default-image.png`;
const ogImage = postData.coverImage
  ? `${siteUrl}${postData.coverImage.src}`
  : defaultImage;

// Determine back link from URL path
const pathname = Astro.url.pathname;
let backHref = "/";
let backLabel = "Home";
if (pathname.startsWith("/writing")) {
  backHref = "/writing";
  backLabel = "Writing";
} else if (pathname.startsWith("/timeline")) {
  backHref = "/timeline";
  backLabel = "Timeline";
} else if (pathname.startsWith("/legal")) {
  backHref = "/legal";
  backLabel = "Legal";
}
---

<Layout>
  <Fragment slot="head">
    <SEO
      title={postData.title}
      description={postData.description}
      openGraph={{
        basic: {
          title: postData.title,
          type: "Article",
          image: ogImage,
        },
      }}
      extend={{
        link: [{ rel: "icon", href: "/favicon.ico" }],
        meta: [
          { name: "twitter:image", content: ogImage },
          { name: "twitter:title", content: postData.title },
          { name: "twitter:description", content: postData.description },
          { name: "twitter:card", content: "summary_large_image" },
        ],
      }}
    />
  </Fragment>

  <div class="min-h-screen c10-bg flex flex-col">
    <div class="flex-grow flex flex-col items-center px-4 md:px-6 py-6">
      <div class="c10-island-article w-full max-w-[50rem] mt-8 md:mt-16">

        <!-- Header -->
        <div class="px-4 md:px-6 pt-4 md:pt-6 pb-5">
          <a href={backHref} class="group inline-flex items-center gap-1 text-xs font-medium c10-back-link mb-4">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            <span>{backLabel}</span>
          </a>

          <div class="flex items-start justify-between gap-4">
            <div class="flex-grow">
              <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-neutral-500 mb-3">
                <time datetime={postData.date}>{postData.formattedDate}</time>
                <span class="inline-block w-1 h-1 rounded-full bg-gray-300 dark:bg-neutral-600"></span>
                <span>{postData.readingTime} min read</span>
              </div>
              <h1
                class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white tracking-tight leading-tight mb-3"
                transition:name={`title-${postData.slug}`}
              >
                {postData.title}
              </h1>
              {postData.description && (
                <p class="text-base md:text-lg text-gray-500 dark:text-neutral-400 leading-relaxed">
                  {postData.description}
                </p>
              )}
              {postData.tags && postData.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {postData.tags.map((tag: string) => (
                    <span class="c10-tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>

            <!-- Share buttons -->
            <div class="flex flex-col gap-3 pt-6 shrink-0">
              <XShare />
              <ShareButton
                title={postData.title}
                text={postData.description}
                url={postData.slug}
              />
            </div>
          </div>
        </div>

        <div class="c10-divider"></div>

        <!-- Prose content -->
        <div class="px-4 md:px-6 py-6 md:py-8">
          <div class="prose prose-gray max-w-none dark:text-neutral-300 dark:prose-invert prose-a:text-[#3D83F6] prose-hr:border-gray-200 prose-hr:dark:border-neutral-800">
            <slot />
          </div>
        </div>

        <!-- Footer -->
        <div class="px-6 md:px-8 pt-3 pb-4 flex items-center justify-between">
          <a href={backHref} class="group flex items-center gap-1 text-xs text-gray-500 dark:text-neutral-400 transition-colors c10-footer-link">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            <span class="font-medium">Back to {backLabel}</span>
          </a>
          <div class="flex items-center gap-4">
            <a href="https://www.linkedin.com/in/robertjkirk/" target="_blank" class="c10-social-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
            <a href="mailto:contact@robertjkirk.com" class="c10-social-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- RK logo pinned bottom center -->
    <div class="group/bottom w-full flex justify-center pb-3 relative">
      <span class="c10-copyright">Copyright &copy; 2026 Robert Kirk</span>
      <a href="/" aria-label="home" class="inline-block c10-logo-link">
        <svg width="42" height="28" viewBox="0 0 949 602" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#c10clip)">
            <path d="M398.411 408.5C437.984 391.325 468.532 366.53 490.056 334.115C511.58 301.7 522.328 263.149 522.3 218.46C522.3 173.716 511.689 135.007 490.468 102.331C469.246 69.6555 439.028 44.4349 399.812 26.6692C360.5 8.82119 314.177 -0.0684959 260.841 0.000150378H0V113.514H252.929C294.81 113.514 326.656 122.547 348.468 140.615C370.28 158.683 381.173 184.631 381.145 218.46C381.145 251.726 370.253 277.516 348.468 295.831C326.683 314.146 294.837 323.324 252.929 323.365H0V602H139.404V434.325H267.62L383.762 602H533.488L398.411 408.5Z" fill="#3D83F6"></path>
            <path d="M684.821 268.297L934.351 0H779.495L561.097 230.342C559.304 277.708 546.365 319.864 522.609 355.656C504.974 382.114 482.117 404.693 455.442 422.01L490.859 472.712L593.753 365.5L786.479 602H949.103L684.821 268.297Z" fill="#3D83F6"></path>
            <path d="M490.756 472.712L455.339 422.01C482.014 404.693 504.87 382.114 522.506 355.656C546.262 319.864 559.201 277.77 560.994 230.342C560.994 230.342 591.219 356.933 490.756 472.712Z" fill="#3D83F6"></path>
          </g>
          <defs><clipPath id="c10clip"><rect width="949" height="602" fill="white"></rect></clipPath></defs>
        </svg>
      </a>
    </div>
  </div>
</Layout>

<style>
  :global([aria-label="rk logo"]) { display: none !important; }
  :global(footer) { display: none !important; }
  :global(html) {
    background: linear-gradient(180deg, #eff6ff 0%, #f0f4ff 30%, #f8fafc 60%, #f1f5f9 100%) !important;
  }
  @media (prefers-color-scheme: dark) {
    :global(html) {
      background: linear-gradient(180deg, #0a0a0a 0%, #0c0c0c 30%, #0a0a0a 60%, #080808 100%) !important;
    }
  }
  .c10-bg {
    background: linear-gradient(180deg, #eff6ff 0%, #f0f4ff 30%, #f8fafc 60%, #f1f5f9 100%);
  }
  @media (prefers-color-scheme: dark) {
    .c10-bg {
      background: linear-gradient(180deg, #0a0a0a 0%, #0c0c0c 30%, #0a0a0a 60%, #080808 100%);
    }
  }

  /* Article island — no overflow:hidden so prose elements render properly */
  .c10-island-article {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border-radius: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.02),
      0 4px 16px rgba(0, 0, 0, 0.03),
      0 16px 48px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      inset 0 -1px 0 rgba(255, 255, 255, 0.2);
  }
  @media (prefers-color-scheme: dark) {
    .c10-island-article {
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(40px) saturate(150%);
      -webkit-backdrop-filter: blur(40px) saturate(150%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow:
        0 1px 2px rgba(0, 0, 0, 0.3),
        0 4px 16px rgba(0, 0, 0, 0.2),
        0 16px 48px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.06),
        inset 0 -1px 0 rgba(255, 255, 255, 0.02);
    }
  }

  .c10-logo-link { transition: opacity 0.15s ease; }
  .c10-logo-link:hover { opacity: 0.7; }
  .c10-copyright {
    position: absolute;
    bottom: 12px;
    left: 16px;
    font-size: 11px;
    color: transparent;
    transition: color 0.3s ease;
    user-select: none;
  }
  .group\/bottom:hover .c10-copyright {
    color: rgba(0, 0, 0, 0.2);
  }
  @media (prefers-color-scheme: dark) {
    .group\/bottom:hover .c10-copyright {
      color: rgba(255, 255, 255, 0.1);
    }
  }
  .c10-divider {
    margin: 0 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.03);
  }
  @media (min-width: 768px) {
    .c10-divider { margin: 0 1.5rem; }
  }
  @media (prefers-color-scheme: dark) {
    .c10-divider { border-color: rgba(255, 255, 255, 0.03); }
  }
  .c10-back-link { color: #3D83F6; }
  .c10-back-link:hover { color: #2b6de0; }
  .c10-footer-link:hover { color: #3D83F6; }
  .c10-social-link {
    color: #d1d5db;
    transition: color 0.15s ease;
  }
  .c10-social-link:hover { color: #3D83F6; }
  @media (prefers-color-scheme: dark) {
    .c10-social-link { color: #525252; }
    .c10-social-link:hover { color: #3D83F6; }
  }
  .c10-tag {
    background: rgba(225, 230, 240, 0.4);
    color: #6b7280;
    font-size: 13px;
    padding: 2px 10px;
    border-radius: 8px;
  }
  @media (prefers-color-scheme: dark) {
    .c10-tag {
      background: rgba(255, 255, 255, 0.06);
      color: #9ca3af;
    }
  }
</style>
