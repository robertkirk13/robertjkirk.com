---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout>
  <div class="min-h-screen c10-bg flex flex-col">
    <div class="flex-grow flex flex-col items-center px-4 md:px-6 py-6">
      <div class="c10-island w-full max-w-3xl mt-8 md:mt-16">

        <!-- Header -->
        <div class="px-4 md:px-6 pt-4 md:pt-5 pb-6 flex items-center justify-between">
          <a href="/" class="group inline-flex items-center gap-1 text-xs font-medium c10-back-link">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            <span>Home</span>
          </a>
          <h1 class="text-sm font-semibold text-gray-900 dark:text-white tracking-wide">
            Writing
          </h1>
          <div class="w-[52px]"></div>
        </div>

        <!-- Filter buttons -->
        <div class="px-4 md:px-6 pb-1 flex gap-2 flex-wrap" id="filter-buttons">
          <button data-filter="All" class="filter-btn active c10-filter-active">All</button>
          <button data-filter="Interactive" class="filter-btn c10-filter-inactive">Interactive</button>
          <button data-filter="Philosophy" class="filter-btn c10-filter-inactive">Philosophy</button>
          <button data-filter="Projects" class="filter-btn c10-filter-inactive">Projects</button>
        </div>

        <!-- Posts -->
        <div class="px-4 md:px-6 pt-4 pb-4 md:pb-6">
          <div class="space-y-4" id="posts-container">
            {sortedPosts.map((post, index) => (
              <a
                href={`/writing/${post.slug}`}
                data-category={post.data.category || ""}
                class="post-item group block c10-card"
              >
                <div class="p-5 md:p-6">
                  {index === 0 && (
                    <div class="flex items-center gap-2 mb-3">
                      <span class="c10-latest-dot"></span>
                      <span class="text-xs font-bold uppercase tracking-widest c10-latest-text">Latest</span>
                    </div>
                  )}
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white transition-colors leading-snug c10-card-title" transition:name={`title-${post.slug}`}>
                    {post.data.title}
                  </h3>
                  {post.data.description && (
                    <p class="text-sm text-gray-500 dark:text-neutral-400 mt-2 leading-relaxed">
                      {post.data.description}
                    </p>
                  )}
                  <div class="flex items-center gap-2 mt-4 text-xs text-gray-400 dark:text-neutral-500">
                    <span>{post.data.formattedDate}</span>
                    <span class="inline-block w-1 h-1 rounded-full bg-gray-300 dark:bg-neutral-600"></span>
                    <span>{post.data.readingTime} min read</span>
                    {post.data.category && (
                      <>
                        <span class="inline-block w-1 h-1 rounded-full bg-gray-300 dark:bg-neutral-600"></span>
                        <span class="c10-category-text">{post.data.category}</span>
                      </>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>


      </div>
    </div>

    <!-- RK logo pinned bottom center -->
    <div class="group/bottom w-full flex justify-center pb-3 relative">
      <span class="c10-copyright">Copyright &copy; 2026 Robert Kirk</span>
      <a href="/" aria-label="home" class="inline-block c10-logo-link">
        <svg width="42" height="28" viewBox="0 0 949 602" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#c10clip)">
            <path d="M398.411 408.5C437.984 391.325 468.532 366.53 490.056 334.115C511.58 301.7 522.328 263.149 522.3 218.46C522.3 173.716 511.689 135.007 490.468 102.331C469.246 69.6555 439.028 44.4349 399.812 26.6692C360.5 8.82119 314.177 -0.0684959 260.841 0.000150378H0V113.514H252.929C294.81 113.514 326.656 122.547 348.468 140.615C370.28 158.683 381.173 184.631 381.145 218.46C381.145 251.726 370.253 277.516 348.468 295.831C326.683 314.146 294.837 323.324 252.929 323.365H0V602H139.404V434.325H267.62L383.762 602H533.488L398.411 408.5Z" fill="#3D83F6"></path>
            <path d="M684.821 268.297L934.351 0H779.495L561.097 230.342C559.304 277.708 546.365 319.864 522.609 355.656C504.974 382.114 482.117 404.693 455.442 422.01L490.859 472.712L593.753 365.5L786.479 602H949.103L684.821 268.297Z" fill="#3D83F6"></path>
            <path d="M490.756 472.712L455.339 422.01C482.014 404.693 504.87 382.114 522.506 355.656C546.262 319.864 559.201 277.77 560.994 230.342C560.994 230.342 591.219 356.933 490.756 472.712Z" fill="#3D83F6"></path>
          </g>
          <defs><clipPath id="c10clip"><rect width="949" height="602" fill="white"></rect></clipPath></defs>
        </svg>
      </a>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const posts = document.querySelectorAll('.post-item');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        // Update button styles
        buttons.forEach(b => {
          b.classList.remove('c10-filter-active');
          b.classList.add('c10-filter-inactive');
        });
        btn.classList.remove('c10-filter-inactive');
        btn.classList.add('c10-filter-active');

        // Filter posts
        posts.forEach(post => {
          const category = (post as HTMLElement).getAttribute('data-category');
          if (filter === 'All' || category === filter) {
            (post as HTMLElement).style.display = 'block';
          } else {
            (post as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>

<style>
  :global([aria-label="rk logo"]) { display: none !important; }
  :global(footer) { display: none !important; }
  :global(html) {
    background: linear-gradient(180deg, #eff6ff 0%, #f0f4ff 30%, #f8fafc 60%, #f1f5f9 100%) !important;
  }
  @media (prefers-color-scheme: dark) {
    :global(html) {
      background: linear-gradient(180deg, #0a0a0a 0%, #0c0c0c 30%, #0a0a0a 60%, #080808 100%) !important;
    }
  }
  .c10-bg {
    background: linear-gradient(180deg, #eff6ff 0%, #f0f4ff 30%, #f8fafc 60%, #f1f5f9 100%);
  }
  @media (prefers-color-scheme: dark) {
    .c10-bg {
      background: linear-gradient(180deg, #0a0a0a 0%, #0c0c0c 30%, #0a0a0a 60%, #080808 100%);
    }
  }
  .c10-island {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border-radius: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.02),
      0 4px 16px rgba(0, 0, 0, 0.03),
      0 16px 48px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      inset 0 -1px 0 rgba(255, 255, 255, 0.2);
    overflow: hidden;
  }
  @media (prefers-color-scheme: dark) {
    .c10-island {
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(40px) saturate(150%);
      -webkit-backdrop-filter: blur(40px) saturate(150%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow:
        0 1px 2px rgba(0, 0, 0, 0.3),
        0 4px 16px rgba(0, 0, 0, 0.2),
        0 16px 48px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.06),
        inset 0 -1px 0 rgba(255, 255, 255, 0.02);
    }
  }
  .c10-logo-link { transition: opacity 0.15s ease; }
  .c10-logo-link:hover { opacity: 0.7; }
  .c10-copyright {
    position: absolute;
    bottom: 12px;
    left: 16px;
    font-size: 11px;
    color: transparent;
    transition: color 0.3s ease;
    user-select: none;
  }
  .group\/bottom:hover .c10-copyright {
    color: rgba(0, 0, 0, 0.2);
  }
  @media (prefers-color-scheme: dark) {
    .group\/bottom:hover .c10-copyright {
      color: rgba(255, 255, 255, 0.1);
    }
  }
  .c10-divider {
    margin: 0 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.03);
  }
  @media (min-width: 768px) {
    .c10-divider { margin: 0 1.5rem; }
  }
  @media (prefers-color-scheme: dark) {
    .c10-divider { border-color: rgba(255, 255, 255, 0.03); }
  }
  .c10-back-link { color: #3D83F6; }
  .c10-back-link:hover { color: #2b6de0; }
  .c10-card {
    position: relative;
    border-radius: 1.75rem;
    overflow: hidden;
    transition: all 0.25s ease;
    background: rgba(225, 230, 240, 0.3);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(50px) saturate(140%);
    -webkit-backdrop-filter: blur(50px) saturate(140%);
  }
  .c10-card > * { position: relative; z-index: 1; }
  .c10-card::before {
    content: '';
    position: absolute;
    inset: -30px;
    background: linear-gradient(135deg, #3D83F6 0%, transparent 60%);
    filter: blur(50px);
    opacity: 0;
    z-index: 0;
    transition: opacity 0.25s ease;
  }
  .c10-card:hover { border-color: rgba(61, 131, 246, 0.1); }
  .c10-card:hover::before { opacity: 0.15; }
  @media (prefers-color-scheme: dark) {
    .c10-card {
      background: rgba(255, 255, 255, 0.025);
      border-color: rgba(255, 255, 255, 0.07);
      box-shadow: none;
      backdrop-filter: blur(50px);
      -webkit-backdrop-filter: blur(50px);
    }
    .c10-card:hover { border-color: rgba(255, 255, 255, 0.1); }
    .c10-card:hover::before { opacity: 0.12; }
  }
  .group:hover .c10-card-title { color: #3D83F6; }
  .c10-footer-link:hover { color: #3D83F6; }
  .c10-latest-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #3D83F6;
    display: inline-block;
  }
  .c10-latest-text { color: #3D83F6; }
  .c10-category-text { color: rgba(61, 131, 246, 0.7); }
  .filter-btn {
    padding: 6px 16px;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.15s ease;
    cursor: pointer;
    border: none;
  }
  .c10-filter-active {
    background: #3D83F6;
    color: white;
  }
  .c10-filter-inactive {
    background: rgba(225, 230, 240, 0.4);
    color: #6b7280;
  }
  .c10-filter-inactive:hover {
    background: rgba(225, 230, 240, 0.6);
  }
  @media (prefers-color-scheme: dark) {
    .c10-filter-inactive {
      background: rgba(255, 255, 255, 0.06);
      color: #9ca3af;
    }
    .c10-filter-inactive:hover {
      background: rgba(255, 255, 255, 0.1);
    }
  }
</style>
